{
  "name": "ai-browser",
  "version": "1.6.14",
  "description": "AI Browser",
  "type": "module",
  "main": "./out/main/index.js",
  "license": "MIT",
  "author": "Jun Murakami",
  "homepage": "https://github.com/Jun-Murakami/AI-Browser",
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome check",
    "lint:fix": "biome check --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "node scripts/fix-pty-module.cjs",
    "postinstall-disabled": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "license-checker --production --json --out src/renderer/src/assets/license.json && npm run build && electron-builder --win",
    "build:mac": "electron-vite build && APPLE_API_KEY_ID=\"$APPLE_API_KEY\" APPLE_API_KEY=\"$APPLE_API_KEY_PATH\" electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build-appx": "electron-builder -w appx"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/m-plus-1p": "^5.2.9",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@tanstack/react-hotkeys": "^0.9.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "electron-context-menu": "^4.1.2",
    "monaco-editor": "^0.53.0",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
